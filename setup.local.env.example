# ============================================================
# LINE Harness 手動セットアップ — ローカル設定 / シークレット
# ------------------------------------------------------------
# 使い方:
#   1. このファイルを setup.local.env にコピー
#        cp setup.local.env.example setup.local.env
#   2. 下の値をすべて埋める（LINE Developers コンソールから取得）
#   3. Claude に「deploy 実行して」と伝える
#        → bash scripts-local/deploy.sh が一括実行されます
#
# setup.local.env は .gitignore 済み。コミットされません。
# このファイル(.example)はプレースホルダーのみなのでコミットOK。
# ============================================================

# --- プロジェクト名（Worker / D1 / Pages の名前に使用。英小文字・数字・ハイフン）---
PROJECT=nagara-tenjin

# --- Messaging API チャネル ---
# https://manager.line.biz/ → 設定 → Messaging API
LINE_CHANNEL_ID=
# 「Messaging API設定」タブ → チャネルアクセストークン（長期）を発行
LINE_CHANNEL_ACCESS_TOKEN=
# Channel ID と同じページに表示される Channel Secret
LINE_CHANNEL_SECRET=

# --- LINE Login チャネル（Messaging API とは別チャネル）---
# https://developers.line.biz/console/ → 新規チャネル → LINE ログイン
LINE_LOGIN_CHANNEL_ID=

# --- LIFF ---
# LINE Login チャネル → 「LIFF」タブ → 追加（Size: Full / Scope: openid,profile,chat_message.write）
# 形式: チャネルID-ランダム文字列（例 2009554425-4IMBmLQ9）
LIFF_ID=
